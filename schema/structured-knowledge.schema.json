{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "structured-knowledge.schema.json",
  "title": "Structured Knowledge Output",
  "type": "object",
  "required": ["session_id", "topic", "expert", "structured_at", "purpose", "knowledge"],
  "additionalProperties": false,
  "properties": {
    "session_id":     { "type": "string" },
    "topic":          { "type": "string" },
    "expert":         { "type": "string" },
    "structured_at":  { "type": "string", "format": "date-time" },
    "purpose":        { "type": "string" },
    "priority_items": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of knowledge objects flagged as highest priority in /knowledge-review"
    },
    "knowledge": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "title", "body", "tags", "confidence"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^session-[0-9]{3}-[0-9]{3}$",
            "description": "e.g. session-001-007"
          },
          "type": {
            "type": "string",
            "enum": ["fact", "concept", "rule", "procedure", "example", "edge_case", "mental_model", "warning"]
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          },
          "body": {
            "type": "string",
            "minLength": 1,
            "description": "Self-contained — readable with no prior context"
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "related_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "priority": {
            "type": "boolean"
          },
          "ambiguity_note": {
            "type": "string",
            "description": "Set when the source was unclear or an assumption was made"
          },
          "source_quote": {
            "type": "string",
            "maxLength": 250,
            "description": "Verbatim excerpt from the interview transcript"
          }
        }
      }
    }
  }
}
